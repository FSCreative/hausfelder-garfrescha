<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Admin Login | Haus Felder Garfrescha</title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="admin-body">
  <div class="admin-login-card">
    <h1>🔒 Admin-Bereich</h1>
    <p>Haus Felder Garfrescha</p>
    <% if (error) { %><div class="alert">⚠ <%= error %></div><% } %>
    <form method="POST" action="/admin/login">
      <input type="password" name="password" placeholder="Passwort" required autofocus>
      <button type="submit" class="btn btn-accent" style="width:100%">Anmelden</button>
    </form>
    <a href="/" class="back-link">← Zurück zur Website</a>
  </div>
</body>
</html>
