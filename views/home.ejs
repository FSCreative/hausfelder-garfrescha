<%- include('partials/header', { title: 'Urlaub auf 1.500 m' }) %>

<section class="hero" id="hero">
  <div class="hero-bg">
    <img id="heroWinter" src="/images/winter-03.jpg" alt="Garfrescha im Winter" class="active">
    <img id="heroSommer" src="/images/sommer-01.jpg" alt="Garfrescha im Sommer">
  </div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <p class="hero-kicker">Ferienwohnung · Garfrescha · Silvretta Montafon</p>
    <h1><%= c.home.heroTitle %></h1>
    <p class="hero-sub">„<%= c.home.heroSubtitle.replace(/^"|"$/g, '') %>“</p>
    <div class="hero-actions">
      <a href="/anfrage" class="btn btn-accent btn-lg">Jetzt anfragen</a>
      <a href="/wohnung" class="btn btn-ghost btn-lg">Wohnung entdecken</a>
    </div>
    <div class="season-toggle" role="group" aria-label="Jahreszeit wählen">
      <button class="season-btn active" data-season="winter">❄ Winter</button>
      <button class="season-btn" data-season="sommer">☀ Sommer</button>
    </div>
  </div>
  <a href="#intro" class="hero-scroll" aria-label="Nach unten scrollen"><span></span></a>
</section>

<section class="section" id="intro">
  <div class="container narrow reveal">
    <h2 class="section-title">Willkommen auf 1.500 Metern</h2>
    <p class="lead"><%= c.home.introText %></p>
  </div>
  <div class="container facts reveal">
    <div class="fact"><span class="fact-icon">⛰</span><%= c.home.factHoehe %></div>
    <div class="fact"><span class="fact-icon">🛏</span><%= c.home.factPersonen %></div>
    <div class="fact"><span class="fact-icon">⛷</span><%= c.home.factSki %></div>
    <div class="fact"><span class="fact-icon">🏡</span><%= c.home.factBaujahr %></div>
  </div>
</section>

<section class="section section-alt">
  <div class="container cards-2">
    <a href="/wohnung" class="card card-img reveal">
      <div class="card-media"><img src="/images/wohnung-aussen.jpg" alt="Unsere Berghütte" loading="lazy"></div>
      <div class="card-body">
        <h3>Unsere Wohnung</h3>
        <p><%= c.home.cardWohnungText %></p>
        <span class="card-link">Erfahre mehr →</span>
      </div>
    </a>
    <a href="/anreise" class="card card-img reveal">
      <div class="card-media"><img src="/images/home-huette-winter.jpg" alt="Anreise nach Garfrescha" loading="lazy"></div>
      <div class="card-body">
        <h3>Infos zur Anreise</h3>
        <p><%= c.home.cardAnreiseText %></p>
        <span class="card-link">Erfahre mehr →</span>
      </div>
    </a>
  </div>
</section>

<section class="section">
  <div class="container welcome reveal">
    <img src="/images/home-familie.jpg" alt="Familie Felder" class="welcome-img">
    <div>
      <h2 class="section-title" style="text-align:left"><%= c.home.welcomeText %></h2>
      <p>Deine Gastgeberin <strong><%= c.kontakt.name %></strong> und Familie heißen dich herzlich willkommen – ob Sommerfrische oder Skiurlaub direkt an der Piste.</p>
      <a href="/kontakt" class="btn btn-outline">Kontakt aufnehmen</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
